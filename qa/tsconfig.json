{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "noEmit": true,
        "rootDir": ".",
        "types": ["node"]
    },
    "include": ["bin/**/*.ts", "lib/**/*.ts", "qa.config.ts"],
    "exclude": ["node_modules", "output", "dist", "scripts"]
}
