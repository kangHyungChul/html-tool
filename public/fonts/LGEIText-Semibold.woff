ssClassNames\":null,\"dynamicComponentId\":\"productwishlist-6dbcdc5ac8\",\"resourcePath\":\"\",\"toggleWishlistEndpoint\":\"/ncmsbtb/api/v1/proxy/cudCustomerWishList?locale=GLOBAL\",\"retrieveWishlistEndpoint\":\"/ncmsbtb/api/v1/proxy/retrieveProductWishList?locale=GLOBAL\",\":type\":\"lgebtb/components/product/productwishlist\",\":items\":{}}}}}},\"productWishlistModel\":{\"signInUrl\":\"/global/login/\",\"wishlistUrl\":\"/global/my-lg/#wishlist-section\",\"editUrl\":\"\",\"appliedCssClassNames\":null,\"dynamicComponentId\":\"productwishlist-6dbcdc5ac8\",\"resourcePath\":\"\",\"toggleWishlistEndpoint\":\"/ncmsbtb/api/v1/proxy/cudCustomerWishList?locale=GLOBAL\",\"retrieveWishlistEndpoint\":\"/ncmsbtb/api/v1/proxy/retrieveProductWishList?locale=GLOBAL\",\":type\":\"lgebtb/components/product/productwishlist\",\":items\":{}},\"klarnaPopupModel\":{\"heading\":\"Klarna\",\"title\":\"Payment Options\",\"subTitle\":null,\"installmentApiKey\":null,\"installmentScriptUrl\":null,\"descTitle1\":null,\"descBody1\":null,\"descTitle2\":\"Long-term Klarna Payment Structure\",\"klarnaInfo\":\"You must be 18+ and a UK resident to be eligible for this credit offer.\",\"descTitle3\":\"About Klarna\",\"descSubtitle3\":\"LG has partnered with Klarna to help give our customers flexible payment options for eligible purchases on LG.com/uk. \",\"descBody3\":\"Please spend responsibly. Borrowing more than you can afford could seriously affect your financial status. Make sure you can afford to make your monthly repayments on time. LG UK is not a lender and acts only as an introducer. The credit product is provided by Klarna Bank AB (publ). Credit is only available to permanent UK residents aged 18 and over, depending on their status. Terms and conditions apply. Please note that Pay in 30 days and Pay in 3 instalments are not regulated by the FCA.\",\"stepContentList\":null,\"descList\":null,\"klarnaMoreItems\":null,\"appliedCssClassNames\":null,\"dynamicComponentId\":\"klarnapopup-d1a0c79d93\",\"resourcePath\":\"\",\":type\":\"lgebtb/components/klarnapopup\",\":items\":{}},\"klarnaPopupXFModel\":{\"title\":\"Klarna Popup\",\"appliedCssClassNames\":null,\"dynamicComponentId\":\"xfpage-b728f8a3ff\",\"resourcePath\":\"\",\":itemsOrder\":[\"root\"],\":type\":\"lgebtb/components/xfpage\",\":items\":{\"root\":{\"gridClassNames\":\"aem-Grid aem-Grid--12 aem-Grid--default--12\",\"columnCount\":12,\"columnClassNames\":{\"klarnapopup\":\"aem-GridColumn aem-GridColumn--default--12\"},\"allowedComponents\":{\"applicable\":false,\"components\":[]},\"id\":\"container-2258a3179b\",\"layout\":\"SIMPLE\",\"accessibilityLabel\":null,\"roleAttribute\":null,\"defaultElement\":null,\"name\":null,\"appliedCssClassNames\":null,\"dynamicComponentId\":\"container-2258a3179b\",\"resourcePath\":\"\",\":itemsOrder\":[\"klarnapopup\"],\":type\":\"lgebtb/components/container\",\":items\":{\"klarnapopup\":{\"heading\":\"Klarna\",\"title\":\"Payment Options\",\"subTitle\":null,\"installmentApiKey\":null,\"installmentScriptUrl\":null,\"descTitle1\":null,\"descBody1\":null,\"descTitle2\":\"Long-term Klarna Payment Structure\",\"klarnaInfo\":\"You must be 18+ and a UK resident to be eligible for this credit offer.\",\"descTitle3\":\"About Klarna\",\"descSubtitle3\":\"LG has partnered with Klarna to help give our customers flexible payment options for eligible purchases on LG.com/uk. \",\"descBody3\":\"Please spend responsibly. Borrowing more than you can afford could seriously affect your financial status. Make sure you can afford to make your monthly repayments on time. LG UK is not a lender and acts only as an introducer. The credit product is provided by Klarna Bank AB (publ). Credit is only available to permanent UK residents aged 18 and over, depending on their status. Terms and conditions apply. Please note that Pay in 30 days and Pay in 3 instalments are not regulated by the FCA.\",\"stepContentList\":[{\"stepNo\":\"Pay in 3\",\"stepContent\":\"Spread the cost of your purchase into 3 interest-free instalments. The first payment is made at point of purchase, with remaining instalments scheduled automatically every 30 days.\",\"klarnaMoreTitle\":null,\"klarnaMoreBody\":null,\"ctaModel\":{\"ctaUrl\":null,\"ctaLabel\":\"\",\"ctaClassName\":null,\"ctaTarget\":null,\"buttonType\":null,\"textLinkColor\":null,\"buttonAlignment\":null,\"anchorId\":null,\"ctaDescription\":\"\",\"ctaType\":null,\"appliedCssClassNames\":null,\"dynamicComponentId\":\"-9ea7fe0ae4\",\"resourcePath\":\"\",\"externalUrl\":false,\"noFollowUrl\":false,\"mappedCtaUrl\":\"\",\":type\":null},\"appliedCssClassNames\":null,\"dynamicComponentId\":\"-9ea7fe0ae4\",\"resourcePath\":\"\",\":type\":null},{\"stepNo\":\"Financing\",\"stepContent\":\"Financing allows you to pay for your purchase in several fixed monthly payments for up to 24 months. *Eligibility for instalment payment options and applicable interest rates may vary depending on individual credit scores. Terms and conditions apply. Subject to approval by the financing provider (Klarna).\",\"klarnaMoreTitle\":null,\"klarnaMoreBody\":null,\"ctaModel\":{\"ctaUrl\":null,\"ctaLabel\":\"\",\"ctaClassName\":null,\"ctaTarget\":null,\"buttonType\":null,\"textLinkColor\":null,\"buttonAlignment\":null,\"anchorId\":null,\"ctaDescription\":\"\",\"ctaType\":null,\"appliedCssClassNames\":null,\"dynamicComponentId\":\"-5ab1ee58de\",\"resourcePath\":\"\",\"externalUrl\":false,\"noFollowUrl\":false,\"mappedCtaUrl\":\"\",\":type\":null},\"appliedCssClassNames\":null,\"dynamicComponentId\":\"-5ab1ee58de\",\"resourcePath\":\"\",\":type\":null},{\"stepNo\":\"How to apply for Klarna financing:\",\"stepContent\":\"1. Select the Financing option in the store’s checkout\",\"klarnaMoreTitle\":null,\"klarnaMoreBody\":null,\"ctaModel\":{\"ctaUrl\":null,\"ctaLabel\":\"\",\"ctaClassName\":null,\"ctaTarget\":null,\"buttonType\":null,\"textLinkColor\":null,\"buttonAlignment\":null,\"anchorId\":null,\"ctaDescription\":\"\",\"ctaType\":null,\"appliedCssClass